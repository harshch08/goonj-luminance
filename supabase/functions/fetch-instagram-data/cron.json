{
  "schedule": "0 * * * *",
  "description": "Fetch Instagram data every hour",
  "enabled": true,
  "timezone": "UTC",
  "retry_policy": {
    "max_retries": 3,
    "retry_delay": "5m",
    "backoff_multiplier": 2
  },
  "timeout": "5m",
  "monitoring": {
    "alert_on_failure": true,
    "alert_threshold": 3,
    "success_webhook": null,
    "failure_webhook": null
  }
}